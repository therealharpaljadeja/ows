{
  "name": "@local-wallet-standard/node",
  "version": "0.2.23",
  "description": "Node.js native bindings for the Lightweight Wallet Signer",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "lws": "bin/lws"
  },
  "napi": {
    "name": "lws-node",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi build --platform --release",
    "publish:all": "node publish.mjs",
    "test": "node --test __test__/index.spec.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "optionalDependencies": {
    "@local-wallet-standard/node-linux-x64-gnu": "0.2.23",
    "@local-wallet-standard/node-linux-arm64-gnu": "0.2.23",
    "@local-wallet-standard/node-darwin-x64": "0.2.23",
    "@local-wallet-standard/node-darwin-arm64": "0.2.23"
  },
  "license": "MIT",
  "files": [
    "index.js",
    "index.d.ts",
    "bin/lws"
  ]
}

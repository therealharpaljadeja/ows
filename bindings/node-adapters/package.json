    "@solana/web3.js": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "viem": { "optional": true },
    "@solana/web3.js": { "optional": true }
  },
  "devDependencies": {
    "viem": "^2.0.0",
    "@solana/web3.js": "^1.95.0"
  },
  "license": "MIT",
  "files": ["src"]
